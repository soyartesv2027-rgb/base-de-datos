ALTER TABLE obras
    ADD COLUMN autor VARCHAR(150) NOT NULL DEFAULT '' AFTER usuario_id;
 CREATE TABLE IF NOT EXISTS favoritos (
    id INT(11) NOT NULL AUTO_INCREMENT,
    obra_id INT(11) NOT NULL,
    usuario_id INT(11) NOT NULL,
    creado_en DATETIME DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (id),
    UNIQUE KEY unico_favorito (obra_id, usuario_id),
    KEY usuario_id (usuario_id),
    CONSTRAINT favoritos_ibfk_1 FOREIGN KEY (obra_id) REFERENCES obras (id) ON DELETE CASCADE,
    CONSTRAINT favoritos_ibfk_2 FOREIGN KEY (usuario_id) REFERENCES usuarios (id) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;
